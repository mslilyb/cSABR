Bootstrap: docker
From: ubuntu:20.04
Stage: spython-base

%files
/home/alrescha/Code/DART /align
%post
mkdir -p /align
cd /align
apt-get update && apt-get install -y --no-install-recommends build-essential libssl-dev zlib1g-dev gcc bzip2 libbz2-dev liblzma-dev
make

%runscript
cd /align
exec bin/dart "$@"
%startscript
cd /align
exec bin/dart "$@"
